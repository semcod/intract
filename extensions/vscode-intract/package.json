{
  "name": "intract-intent-contracts",
  "displayName": "Intract Intent Contracts",
  "description": "Highlight @intract.v1 intent contract comments and run validation tasks.",
  "version": "0.1.0",
  "publisher": "semcod",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/semcod/intract.git"
  },
  "bugs": {
    "url": "https://github.com/semcod/intract/issues"
  },
  "homepage": "https://github.com/semcod/intract#readme",
  "keywords": [
    "intract",
    "intent",
    "contracts",
    "validation",
    "lint"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Linters", "Other"],
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:csharp",
    "onLanguage:java",
    "onLanguage:go",
    "onLanguage:rust"
  ],
  "main": "./extension.js",
  "contributes": {
    "grammars": [
      {
        "scopeName": "comment.intract.injection",
        "path": "./syntaxes/intract.tmLanguage.json",
        "injectTo": [
          "source.python",
          "source.ts",
          "source.tsx",
          "source.js",
          "source.jsx",
          "source.cs",
          "source.java",
          "source.go",
          "source.rust"
        ]
      }
    ],
    "configuration": {
      "title": "Intract",
      "properties": {
        "intract.manifest": {
          "type": "string",
          "default": "intract.yaml",
          "description": "Default manifest path for validation tasks."
        },
        "intract.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Python executable used to run the intract CLI."
        }
      }
    },
    "commands": [
      {
        "command": "intract.validateProject",
        "title": "Intract: Validate Project"
      },
      {
        "command": "intract.checkStaged",
        "title": "Intract: Check Staged (Hunks)"
      },
      {
        "command": "intract.webAppDemo",
        "title": "Intract: Web App Demo (reports)"
      },
      {
        "command": "intract.webAppMock",
        "title": "Intract: Open Web App Mock"
      }
    ],
    "taskDefinitions": [
      {
        "type": "intract",
        "required": ["task"],
        "properties": {
          "task": {
            "type": "string",
            "description": "Intract task name"
          }
        }
      }
    ]
  },
  "scripts": {
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  }
}
